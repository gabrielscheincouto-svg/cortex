# ──────────────────────────────────────────────────────────────
# CECOPEL 2.0 — API Go · variáveis de ambiente
# Copie para .env (não commitar) e preencha com os valores do seu projeto Supabase.
# ──────────────────────────────────────────────────────────────

# Ambiente: development | staging | production
APP_ENV=development

# Porta HTTP
PORT=8080

# ─── Banco (Supabase) ─────────────────────────────────────────
# Pegar em: Project Settings → Database → Connection string → "Direct connection"
# OU usar o pooler PgBouncer (recomendado em produção, port 6543)
DATABASE_URL=postgres://postgres.xxxxxxxxxxx:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# ─── Supabase (Auth + Storage) ────────────────────────────────
# Pegar em: Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui-bem-longo

# ─── CORS ─────────────────────────────────────────────────────
# Lista de origens permitidas separadas por vírgula
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.cecopel.com.br,https://admin.cecopel.com.br

# ─── Notificações (futuro) ────────────────────────────────────
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
RESEND_API_KEY=

# ─── Cobrança (futuro) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Observabilidade (futuro) ─────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=debug
